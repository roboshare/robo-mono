# Template for foundry environment variables.

# For local development, copy this file, rename it to .env, and fill in the values.

# We provide default values so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# DEPLOYER_PRIVATE_KEY is used while deploying contract.
# On anvil chain the value of it can be empty since we use the prefunded account
# which comes with anvil chain to deploy contract.
# NOTE: You don't need to manually change the value of DEPLOYER_PRIVATE_KEY, it should
# be auto filled when run `yarn generate`.

# RPC API keys used by provider-specific aliases in `foundry.toml`.
ALCHEMY_API_KEY=
INFURA_API_KEY=

# Optional default provider for deploy/verify/fork commands.
# Supported values: infura, alchemy. Defaults to infura when unset.
# You can also pass `--rpc-provider alchemy` per command.
RPC_PROVIDER=

# Block explorer API key for contract verification across Etherscan-supported chains.
# Base Sepolia verification still requires an account/key with the paid Base tier enabled.
ETHERSCAN_API_KEY=

# Graph Studio deploy key for publishing the managed subgraph.
# Use this from protocols/evm when authenticating or deploying the subgraph.
GRAPH_DEPLOY_KEY=

# Graph Studio subgraph slug.
# Create the subgraph first in Studio, then set this to the exact slug shown there
# (for example: your-org-or-user/roboshare-protocol).
GRAPH_SUBGRAPH_SLUG=

# Keystore account for deployments
# - "scaffold-eth-default": Anvil's prefunded account (localhost only, no password)
# - For production: set to your keystore name (e.g., "my-deployer-wallet")
# - If not set or "scaffold-eth-default" on non-localhost, you'll be prompted to select
ETH_KEYSTORE_ACCOUNT=scaffold-eth-default

# Treasury fee recipient address (required for public deployments)
# This should be a multi-sig address for mainnet and public testnet deployments
# For localhost only, this is optional and the deployer address will be used as fallback
# TREASURY_FEE_RECIPIENT=0xYourMultiSigAddress

# Optional: USDC address for localhost deployments
# Set this if you want to reuse a specific MockUSDC Deployment across multiple scripts
# USDC_ADDRESS=0xMockUSDCAddress
