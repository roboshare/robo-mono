{
  "name": "robo-mono",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "protocols/*",
      "protocols/evm/subgraph",
      "web"
    ]
  },
  "scripts": {
    "dev": "./scripts/start-dev.sh",
    "dev:reset": "./scripts/start-dev.sh --reset",
    "dev:kill": "./scripts/start-dev.sh --kill",
    "account": "yarn evm:account",
    "account:generate": "yarn evm:generate",
    "account:import": "yarn evm:account-import",
    "account:reveal-pk": "yarn workspace evm account:reveal-pk",
    "chain": "yarn evm:chain",
    "compile": "yarn evm:compile",
    "deploy": "yarn evm:deploy",
    "deploy:verify": "yarn evm:deploy-verify",
    "upgrade": "yarn evm:upgrade",
    "flatten": "yarn evm:flatten",
    "fork": "yarn evm:fork",
    "format": "yarn web:format && yarn evm:format",
    "evm:account": "yarn workspace evm account",
    "evm:account-import": "yarn workspace evm account:import",
    "evm:chain": "yarn workspace evm chain",
    "evm:clean": "yarn workspace evm clean",
    "evm:compile": "yarn workspace evm compile",
    "evm:deploy": "yarn workspace evm deploy",
    "evm:upgrade": "yarn workspace evm upgrade",
    "evm:deploy-verify": "yarn workspace evm deploy:verify",
    "evm:flatten": "yarn workspace evm flatten",
    "evm:fork": "yarn workspace evm fork",
    "evm:format": "yarn workspace evm format",
    "evm:generate": "yarn workspace evm account:generate",
    "evm:generate:protocol-config": "yarn workspace evm generate:protocol-config",
    "evm:lint": "yarn workspace evm lint",
    "evm:storage-layout:check": "yarn workspace evm storage:layout:check",
    "evm:storage-layout:snapshot": "yarn workspace evm storage:layout:snapshot",
    "evm:test": "yarn workspace evm test",
    "evm:test:fork": "yarn workspace evm test:fork",
    "evm:test:fork:nightly": "yarn workspace evm test:fork:nightly",
    "evm:coverage": "yarn workspace evm coverage",
    "evm:verify": "yarn workspace evm verify",
    "generate": "yarn evm:generate",
    "graph": "yarn workspace subgraph graph",
    "graphclient:build": "yarn workspace web client",
    "postinstall": "husky install",
    "ipfs": "yarn workspace web ipfs",
    "lint": "yarn web:lint && yarn evm:lint",
    "robomata:local-smoke": "yarn workspace web robomata:local-smoke",
    "robomata:agent-boundary-smoke": "yarn workspace web robomata:agent-boundary-smoke",
    "robomata:agent-execution-smoke": "yarn workspace web robomata:agent-execution-smoke",
    "robomata:agent-planner-intents-smoke": "yarn workspace web robomata:agent-planner-intents-smoke",
    "robomata:agent-planner-provenance-smoke": "yarn workspace web robomata:agent-planner-provenance-smoke",
    "robomata:google-gemini-adapter-smoke": "yarn workspace web robomata:google-gemini-adapter-smoke",
    "robomata:llm-review-controls-smoke": "yarn workspace web robomata:llm-review-controls-smoke",
    "robomata:llm-review-provenance-smoke": "yarn workspace web robomata:llm-review-provenance-smoke",
    "robomata:policy-artifact-lookup-smoke": "yarn workspace web robomata:policy-artifact-lookup-smoke",
    "robomata:rental-investor-ui-smoke": "yarn workspace web robomata:rental-investor-ui-smoke",
    "robomata:rental-earnings-executor-smoke": "yarn workspace web robomata:rental-earnings-executor-smoke",
    "robomata:rental-marketplace-ui-smoke": "yarn workspace web robomata:rental-marketplace-ui-smoke",
    "robomata:rental-host-ops-ui-smoke": "yarn workspace web robomata:rental-host-ops-ui-smoke",
    "robomata:rental-persistence:bootstrap": "yarn workspace web robomata:rental-persistence:bootstrap",
    "robomata:rental-verification-providers-smoke": "yarn workspace web robomata:rental-verification-providers-smoke",
    "robomata:rental-stripe-payments-smoke": "yarn workspace web robomata:rental-stripe-payments-smoke",
    "robomata:tokenization-api-test": "yarn workspace web robomata:tokenization-api-test",
    "robomata:testnet-smoke": "yarn workspace web robomata:testnet-smoke",
    "web:build": "yarn workspace web build",
    "web:check-types": "yarn workspace web check-types",
    "web:format": "yarn workspace web format",
    "web:lint": "yarn workspace web lint",
    "web:serve": "yarn workspace web serve",
    "precommit": "lint-staged",
    "start": "yarn workspace web dev",
    "subgraph:abi-copy": "yarn workspace subgraph abi-copy",
    "subgraph:auth": "sh -c 'set -a; [ -f protocols/evm/.env ] && . protocols/evm/.env; set +a; yarn workspace subgraph auth'",
    "subgraph:build": "sh -c 'network=\"${SUBGRAPH_NETWORK:-localhost}\"; while [ $# -gt 0 ]; do case \"$1\" in --network|-n) network=\"$2\"; shift 2 ;; *) echo \"Unsupported argument for subgraph:build: $1\"; exit 1 ;; esac; done; export SUBGRAPH_NETWORK=\"$network\"; yarn workspace subgraph abi-copy --network \"$network\" && yarn workspace subgraph codegen && yarn workspace subgraph build' --",
    "subgraph:clean-node": "yarn workspace subgraph clean-node",
    "subgraph:codegen": "sh -c 'network=\"${SUBGRAPH_NETWORK:-localhost}\"; while [ $# -gt 0 ]; do case \"$1\" in --network|-n) network=\"$2\"; shift 2 ;; *) echo \"Unsupported argument for subgraph:codegen: $1\"; exit 1 ;; esac; done; export SUBGRAPH_NETWORK=\"$network\"; yarn workspace subgraph abi-copy --network \"$network\" && yarn workspace subgraph codegen' --",
    "subgraph:create-local": "yarn workspace subgraph create-local",
    "subgraph:deploy": "sh -c 'set -a; [ -f protocols/evm/.env ] && . protocols/evm/.env; set +a; network=\"${SUBGRAPH_NETWORK:-localhost}\"; version_label=\"\"; while [ $# -gt 0 ]; do case \"$1\" in --network|-n) network=\"$2\"; shift 2 ;; --version-label) version_label=\"$2\"; shift 2 ;; *) echo \"Unsupported argument for subgraph:deploy: $1\"; exit 1 ;; esac; done; export SUBGRAPH_NETWORK=\"$network\"; yarn workspace subgraph abi-copy --network \"$network\" && yarn workspace subgraph codegen --network \"$network\" && if [ -n \"$version_label\" ]; then yarn workspace subgraph deploy --network \"$network\" --version-label \"$version_label\"; else yarn workspace subgraph deploy --network \"$network\"; fi' --",
    "subgraph:local-ship": "yarn workspace subgraph local-ship",
    "subgraph:local-ship-auto": "yarn workspace subgraph local-ship-auto",
    "subgraph:run-node": "yarn workspace subgraph run-node",
    "subgraph:stop-node": "yarn workspace subgraph stop-node",
    "subgraph:test": "yarn workspace subgraph test -d",
    "test": "yarn evm:test",
    "test:fork": "yarn evm:test:fork",
    "coverage": "yarn evm:coverage",
    "vercel": "yarn workspace web vercel",
    "vercel:link": "sh -c 'cd web && vercel link'",
    "vercel:start": "sh -c 'cd web && vercel env run -- yarn dev'",
    "vercel:login": "yarn workspace web vercel:login",
    "vercel:yolo": "yarn workspace web vercel:yolo",
    "verify": "yarn evm:verify"
  },
  "devDependencies": {
    "husky": "~9.1.6",
    "lint-staged": "~13.2.2"
  },
  "packageManager": "yarn@3.2.3",
  "engines": {
    "node": ">=24 <25"
  }
}
