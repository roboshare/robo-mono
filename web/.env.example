# Template for NextJS environment variables.

# For local development, copy this file, rename it to .env.local, and fill in the values.
# When deploying live, you'll need to store the vars in Vercel/System config.

# Local development may use scaffold defaults for quick prototyping (check `scaffold.config.ts`).
# Deployed preview/production environments should configure explicit RPC providers.

# To access the values stored in this env file you can use: process.env.VARIABLENAME
# You'll need to prefix the variables names with NEXT_PUBLIC_ if you want to access them on the client side.
# More info: https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables
NEXT_PUBLIC_INFURA_API_KEY=
NEXT_PUBLIC_ALCHEMY_API_KEY=
# Set true locally if you want to disable the Scaffold-ETH fallback Alchemy key.
NEXT_PUBLIC_DISABLE_DEFAULT_ALCHEMY_API_KEY=
# Set true only when you intentionally want viem's chain-default public RPC fallback in deployed browser builds.
NEXT_PUBLIC_ENABLE_PUBLIC_RPC_FALLBACK=
# Optional per-request block range for browser event-history reads. Defaults to 50000 blocks.
NEXT_PUBLIC_EVENT_HISTORY_BLOCK_RANGE=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional Privy embedded wallet creation mode. Defaults to users-without-wallets.
# Use all-users for QA accounts that already have a linked external wallet but need an embedded wallet in this browser.
NEXT_PUBLIC_PRIVY_EMBEDDED_WALLET_CREATE_ON_LOGIN=

# Optional host-aware IA routing overrides.
# Defaults: marketing hosts roboshare.finance,www.roboshare.finance; app host app.roboshare.finance.
# Localhost and preview hosts are not redirected unless their hostnames are explicitly listed here.
ROBOSHARE_MARKETING_HOSTS=
ROBOSHARE_PRIMARY_MARKETING_HOST=
ROBOSHARE_APP_HOST=
# Client-visible app host used only to hide marketing-only CTAs when already inside the app.
NEXT_PUBLIC_ROBOSHARE_APP_HOST=

# Optional per-chain frontend RPC fallbacks. Used after Infura and explicit Alchemy.
# Prefer NEXT_PUBLIC_INFURA_API_KEY for the release default instead of hand-built Infura URLs.
# Example custom URLs:
#   NEXT_PUBLIC_RPC_URL_1=https://mainnet.infura.io/v3/<INFURA_API_KEY>
#   NEXT_PUBLIC_RPC_URL_11155111=https://sepolia.infura.io/v3/<INFURA_API_KEY>
#   NEXT_PUBLIC_RPC_URL_80002=https://polygon-amoy.infura.io/v3/<INFURA_API_KEY>
#   NEXT_PUBLIC_RPC_URL_421614=https://arbitrum-sepolia.infura.io/v3/<INFURA_API_KEY>
#   NEXT_PUBLIC_RPC_URL_84532=https://base-sepolia.infura.io/v3/<INFURA_API_KEY>
#   NEXT_PUBLIC_RPC_URL_10143=https://monad-testnet.infura.io/v3/<INFURA_API_KEY>
NEXT_PUBLIC_RPC_URL_1=
NEXT_PUBLIC_RPC_URL_11155111=
NEXT_PUBLIC_RPC_URL_80002=
NEXT_PUBLIC_RPC_URL_421614=
NEXT_PUBLIC_RPC_URL_84532=
NEXT_PUBLIC_RPC_URL_10143=

NEXT_PUBLIC_SUBGRAPH_URL_11155111=
NEXT_PUBLIC_SUBGRAPH_URL_80002=
NEXT_PUBLIC_SUBGRAPH_URL_421614=
NEXT_PUBLIC_SUBGRAPH_URL_10143=

# Release gate for the in-progress Robomata working submission flow.
# Keep unset/false for release environments until the Robomata QA gate passes.
NEXT_PUBLIC_ENABLE_ROBOMATA_WORKFLOW=
# Server-side gate for Robomata API routes. Keep false unless the workflow is intentionally enabled.
ROBOMATA_WORKFLOW_ENABLED=
# Separate write gate for create/import/upload/compute/commit mutations.
ROBOMATA_WORKFLOW_MUTATIONS_ENABLED=
# Server-side gate for protected lender packet share-link APIs.
ROBOMATA_SHARE_LINKS_ENABLED=
# Client-visible companion flag for showing share-link UI controls.
NEXT_PUBLIC_ROBOMATA_SHARE_LINKS_ENABLED=
# Server-side gate for borrowing-base-to-tokenization APIs. Requires the Robomata workflow and mutations to be enabled.
ROBOMATA_TOKENIZATION_ENABLED=
# Client-visible companion flag for showing tokenization controls and tokenized facility dashboard assets.
NEXT_PUBLIC_ROBOMATA_TOKENIZATION_ENABLED=
# Production registry mapping for tokenization. Use either per-chain variables or a JSON map.
# Example: ROBOMATA_FACILITY_REGISTRY_ADDRESS_10143=0x...
# Example: ROBOMATA_FACILITY_REGISTRY_ADDRESSES_JSON={"10143":"0x..."}
ROBOMATA_FACILITY_REGISTRY_ADDRESSES_JSON=
ROBOMATA_FACILITY_REGISTRY_ADDRESS_10143=
# Local-only test helper for tokenization metadata. If true outside production, prepare uses deterministic mock IPFS URIs.
ROBOMATA_TOKENIZATION_MOCK_METADATA_ENABLED=
# Local-only test helper for tokenization API smoke. If set outside production, prepare can use this FacilityRegistry address.
ROBOMATA_TOKENIZATION_MOCK_REGISTRY_ADDRESS=
# Local-only test helper for tokenization API smoke. If true outside production, complete skips live receipt lookup.
ROBOMATA_TOKENIZATION_MOCK_COMPLETION_VERIFICATION_ENABLED=
# Server-side gate for live facility monitoring projections and APIs. Additive; keeps current submission flow unchanged when false.
ROBOMATA_FACILITY_MONITORING_ENABLED=
# Client-visible companion flag for showing facility monitoring UI.
NEXT_PUBLIC_ROBOMATA_FACILITY_MONITORING_ENABLED=
# Side-effect gate for active monitoring refresh jobs or provider reads. Keep false unless refresh behavior is intentionally enabled.
ROBOMATA_FACILITY_MONITORING_REFRESH_ENABLED=
# Optional local-only JSON file fallback for facility monitoring records when POSTGRES_URL is not configured.
ROBOMATA_FACILITY_MONITORING_FILE=
# Server-side gate for supervised Robomata agent policies, runs, and proposed actions.
ROBOMATA_AGENTS_ENABLED=
# Client-visible companion flag for showing agent supervision UI.
NEXT_PUBLIC_ROBOMATA_AGENTS_ENABLED=
# Separate write gate for agent policy changes, manual runs, and action decisions.
ROBOMATA_AGENT_MUTATIONS_ENABLED=
# Route gate for caller-scheduled agent ticks. This does not start a durable scheduler or worker.
ROBOMATA_AGENT_REFRESH_ENABLED=
# Required for POST /api/robomata/agents/tick; callers must send this value in x-robomata-agent-tick-secret.
ROBOMATA_AGENT_TICK_SECRET=
# Optional local-only JSON file fallback for agent policy/run/action records when POSTGRES_URL is not configured.
ROBOMATA_AGENTS_FILE=
# Server-side gate for facility-backed rental inventory ingestion APIs.
ROBOMATA_RENTAL_INVENTORY_ENABLED=
# Separate side-effect gate for scheduled FacilityRegistry rental-inventory sync.
ROBOMATA_RENTAL_INVENTORY_SCHEDULED_SYNC_ENABLED=
# Vercel Cron bearer secret for scheduled rental-inventory sync.
CRON_SECRET=
# Optional fallback bearer secret for manual non-Vercel rental-inventory sync callers.
ROBOMATA_RENTAL_INVENTORY_SYNC_SECRET=
# Optional local-only JSON file fallback for rental inventory manifests and vehicle records when POSTGRES_URL is not configured.
ROBOMATA_RENTAL_INVENTORY_FILE=
# Optional first block for FacilityRegistry rental-inventory sync when no checkpoint exists.
ROBOMATA_RENTAL_INVENTORY_SYNC_FROM_BLOCK=
# Optional maximum block span for one FacilityRegistry rental-inventory sync call. Defaults to 5000.
ROBOMATA_RENTAL_INVENTORY_SYNC_MAX_BLOCK_RANGE=
# Optional gateway for resolving ipfs:// rental inventory metadata URIs.
ROBOMATA_RENTAL_INVENTORY_IPFS_GATEWAY=
# Server-side gate for renter checkout payment planning and provider orchestration.
ROBOMATA_RENTAL_PAYMENTS_ENABLED=
# MVP renter payment provider. Supported value: stripe.
ROBOMATA_RENTAL_PAYMENT_PROVIDER=stripe
# Server-only shared secret accepted on x-robomata-payment-confirmation from payment-provider/admin callbacks.
ROBOMATA_RENTAL_PAYMENT_CONFIRMATION_SECRET=
# Stripe server key for renter checkout payment intents. Keep unset until provider writes are enabled.
STRIPE_SECRET_KEY=
# Stripe webhook signing secret for renter checkout payment/refund/dispute events.
STRIPE_WEBHOOK_SECRET=
# Stripe publishable key for future client checkout UI.
STRIPE_PUBLISHABLE_KEY=
# Server-side gate for renter account and verification APIs.
ROBOMATA_RENTER_ACCOUNTS_ENABLED=
# Optional local-only JSON file fallback for renter profiles when POSTGRES_URL is not configured.
ROBOMATA_RENTER_ACCOUNTS_FILE=
# Optional bearer secret for verification-provider or ops updates to renter verification states.
ROBOMATA_RENTER_VERIFICATION_SECRET=
# Server-side gate for rental booking checkout and confirmation APIs.
ROBOMATA_RENTAL_BOOKINGS_ENABLED=
# Optional local-only JSON file fallback for rental bookings when POSTGRES_URL is not configured.
ROBOMATA_RENTAL_BOOKINGS_FILE=
# Optional local-only JSON file fallback for rental trip check-in/out records when POSTGRES_URL is not configured.
ROBOMATA_RENTAL_TRIPS_FILE=
# Optional local-only JSON file fallback for rental support incidents and audit events when POSTGRES_URL is not configured.
ROBOMATA_RENTAL_SUPPORT_FILE=
# Optional local-only JSON file fallback for rental claims and payout holds when POSTGRES_URL is not configured.
ROBOMATA_RENTAL_CLAIMS_FILE=
# Server-side gate for rental revenue posting batch APIs.
ROBOMATA_RENTAL_REVENUE_POSTING_ENABLED=
# Optional local-only JSON file fallback for rental revenue ledger entries and posting batches.
ROBOMATA_RENTAL_REVENUE_FILE=
# Server-side gate for investor KPI, dashboard, variance, and attestation reporting APIs.
ROBOMATA_RENTAL_INVESTOR_REPORTING_ENABLED=
# Server-side gate for including monitoring freshness in protected lender views.
ROBOMATA_LENDER_MONITORING_SHARE_ENABLED=
# Client-visible companion flag for showing lender monitoring share controls.
NEXT_PUBLIC_ROBOMATA_LENDER_MONITORING_SHARE_ENABLED=
# Required when protected lender packet sharing is enabled outside local development.
ROBOMATA_SHARE_LINK_TOKEN_SECRET=
# Optional local-only file fallback for share links when POSTGRES_URL is not configured.
ROBOMATA_SHARE_LINKS_FILE=
# Required for enabled Robomata workflow and rental APIs in deployed environments.
# Run `yarn robomata:rental-persistence:bootstrap` with this value before enabling rental flags in preview or production.
# Local-only development may use feature-specific ROBOMATA_*_FILE fallbacks instead.
POSTGRES_URL=
# Separate side-effect gate for real Walrus publisher uploads. If false, evidence uploads use deterministic mock refs.
ROBOMATA_WALRUS_UPLOADS_ENABLED=
# Optional QA/release gate. If true, evidence upload fails unless real Walrus uploads are enabled and Seal is configured.
ROBOMATA_REQUIRE_REAL_EVIDENCE_STORAGE=
# Required with ROBOMATA_WALRUS_UPLOADS_ENABLED=true. Walrus publisher base URL used for encrypted evidence uploads.
WALRUS_PUBLISHER_URL=
# Optional Walrus aggregator base URL shown with uploaded evidence metadata.
WALRUS_AGGREGATOR_URL=
# Optional Walrus storage epoch count. Defaults to 3.
WALRUS_STORAGE_EPOCHS=
# Optional maximum evidence upload size in bytes. Defaults to 10485760.
ROBOMATA_EVIDENCE_UPLOAD_MAX_BYTES=
# Optional maximum receivables CSV import size in bytes. Defaults to 2097152.
ROBOMATA_RECEIVABLES_IMPORT_MAX_BYTES=
# Optional Seal package override. Defaults to ROBOMATA_SUI_PACKAGE_ID when unset.
ROBOMATA_SEAL_PACKAGE_ID=
# Optional Seal identity override. Defaults to the mapped submission facility object or ROBOMATA_SUI_FACILITY_ID.
ROBOMATA_SEAL_IDENTITY=
# Optional Seal key-server config JSON array. Takes precedence over single key-server fields.
ROBOMATA_SEAL_KEY_SERVERS_JSON=
# Optional single Seal key-server object ID. Required for non-testnet Seal encryption unless JSON config is set.
ROBOMATA_SEAL_KEY_SERVER_OBJECT_ID=
# Optional Seal key-server aggregator URL. Defaults to the public testnet aggregator on testnet.
ROBOMATA_SEAL_KEY_SERVER_AGGREGATOR_URL=
# Optional Seal threshold. Defaults to 1.
ROBOMATA_SEAL_THRESHOLD=
# Optional fullnode URL override for Seal encryption. Defaults to the configured Sui network fullnode.
ROBOMATA_SUI_FULLNODE_URL=
# Separate side-effect gate for Sui evidence commits. If false, commits stay prepared even when Sui env exists.
ROBOMATA_SUI_COMMIT_ENABLED=
# Optional side-effect gate for operator-owned Sui wallet commits. Requires ROBOMATA_SUI_COMMIT_ENABLED=true,
# ROBOMATA_SUI_PACKAGE_ID, a persisted submission facility assignment, native sponsorship, and a browser Sui wallet
# that exposes sui:signTransaction.
ROBOMATA_SUI_OPERATOR_COMMIT_ENABLED=
# Optional native Sui gas-sponsorship gate for operator-owned commits. Requires ROBOMATA_SUI_COMMIT_ENABLED=true,
# ROBOMATA_SUI_OPERATOR_COMMIT_ENABLED=true, ROBOMATA_SUI_PACKAGE_ID, persisted facility assignment, and
# ROBOMATA_SUI_PRIVATE_KEY.
ROBOMATA_SUI_SPONSORSHIP_ENABLED=
# Optional safety check for the derived sponsor address.
ROBOMATA_SUI_SPONSOR_ADDRESS=
# Optional sponsor gas budget in MIST. Defaults to ROBOMATA_SUI_GAS_BUDGET or 100000000.
ROBOMATA_SUI_SPONSOR_GAS_BUDGET=
# Optional minimum SUI coin balance in MIST for selecting a sponsor gas coin. Defaults to at least 100000000.
ROBOMATA_SUI_SPONSOR_MIN_COIN_BALANCE=
# Optional maximum number of sponsor SUI coin pages to scan before failing. Defaults to 10 pages of 50 coins.
ROBOMATA_SUI_SPONSOR_COIN_QUERY_MAX_PAGES=
# Optional TTL in milliseconds for prepared native Sui sponsor gas reservations. Defaults to the commit stale window.
ROBOMATA_SUI_SPONSOR_RESERVATION_TTL_MS=
# Optional operator onboarding gate. If true, Robomata verifies the signed-in Privy user and provisions or reuses
# a Privy-managed Sui wallet owned by that user for facility-operator mapping.
ROBOMATA_PRIVY_SUI_WALLET_BINDING_ENABLED=
# Client-visible companion flag for showing and auto-ensuring the Privy Sui wallet binding in the partner UI.
NEXT_PUBLIC_ROBOMATA_PRIVY_SUI_WALLET_BINDING_ENABLED=
# Optional Privy Sui policy id attached to newly created Robomata operator wallets.
ROBOMATA_PRIVY_SUI_WALLET_POLICY_ID=
# Local-only file-store path for Privy Sui wallet bindings when POSTGRES_URL is not configured.
ROBOMATA_OPERATOR_SUI_WALLETS_FILE=
# Required with ROBOMATA_SUI_COMMIT_ENABLED=true. Published Sui package id containing the Robomata facility module.
ROBOMATA_SUI_PACKAGE_ID=
# Single server-held Sui key. It creates Sui facility objects for bound operator wallets and signs only as gas
# sponsor in the intended operator-owned native sponsorship path. It is reused as the legacy server signer only when
# ROBOMATA_SUI_OPERATOR_COMMIT_ENABLED is false and the derived address matches ROBOMATA_SUI_SIGNER_ADDRESS plus the
# persisted facility operator.
ROBOMATA_SUI_PRIVATE_KEY=
# Local-development fallback for Robomata API auth when PartnerManager cannot be read.
# Deployed environments verify PartnerManager directly and should leave this unset.
ROBOMATA_AUTHORIZED_PARTNER_ADDRESSES=
# Optional JSON map for smart-wallet partner identities whose API proof is signed by a separate EOA.
ROBOMATA_AUTHORIZED_PARTNER_SIGNERS_JSON=
# Local-only file-store path for single-developer Robomata workflow runs when POSTGRES_URL is not configured.
ROBOMATA_SUBMISSIONS_FILE=
# Expected active Sui signer address for the legacy server-side signer path. Must match the persisted facility operator.
ROBOMATA_SUI_SIGNER_ADDRESS=
# Optional number of Sui EvidenceCommitted events to request per stale-commit reconciliation page.
ROBOMATA_SUI_EVENT_QUERY_LIMIT=
# Optional maximum number of Sui event pages to scan before a stale commit can be released.
ROBOMATA_SUI_EVENT_QUERY_MAX_PAGES=
# Optional Sui SDK request timeout in milliseconds. Defaults to 120000.
ROBOMATA_SUI_TIMEOUT_MS=

# IPFS Gateway for resolving ipfs:// URLs
# Local development (default): http://127.0.0.1:8080/ipfs/
# Production examples:
#   - https://gateway.pinata.cloud/ipfs/
#   - https://<your-gateway-subdomain>.mypinata.cloud/ipfs/
#   - https://ipfs.io/ipfs/
#   - https://dweb.link/ipfs/
NEXT_PUBLIC_IPFS_GATEWAY=

# Optional: local IPFS node upload endpoint for development
# If omitted in local dev, uploads fall back to http://127.0.0.1:5001/api/v0/add
IPFS_API_URL=

# Pinata server-side upload credentials
# Use a JWT with org:files:write access
PINATA_JWT=

# Optional: upload into a specific Pinata group
PINATA_GROUP_ID=
